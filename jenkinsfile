pipeline {
    agent any

    stages {

        stage('job1-test') {
            steps {
                git 'https://github.com/Git-Mahesh06/prt-ci-cd.git'
            }
        }

        stage('job2-build') {
            steps {
                sh 'docker build -t prt-app:latest .'
            }
        }

        stage('job3-prod') {
            steps {
                sh 'docker run -d -p 8081:80 prt-app:latest'
            }
        }
    }
}